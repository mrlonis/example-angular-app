{
  "name": "example-angular-app",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "build": "ng build",
    "build:dev": "npm run build -- --configuration development",
    "lint": "npm run lint:angular && npm run lint:style && npm run lint:playwright && npm run lint:json && npm run lint:markdown",
    "lint:angular": "ng lint",
    "lint:fix": "npm run lint:angular -- --fix && npm run lint:style -- --fix && npm run lint:playwright -- --fix && npm run lint:json -- --fix && npm run lint:markdown -- --fix",
    "lint:json": "eslint -c ./eslint.config.js --ext .json,.jsonc,.json5 .",
    "lint:markdown": "eslint -c ./eslint.config.js --ext .md .",
    "lint:playwright": "eslint -c ./tests/eslint.config.js ./tests",
    "lint:style": "stylelint 'src/**/*.scss'",
    "ng": "ng",
    "playwright:install": "playwright install --with-deps",
    "prepare": "husky",
    "prettier": "prettier --write . --ignore-unknown",
    "prettier:test": "prettier --check . --ignore-unknown",
    "start": "ng serve",
    "sync:agent-instructions": "node scripts/sync-agent-instructions.mjs",
    "sync:agent-instructions:check": "node scripts/sync-agent-instructions.mjs --check",
    "test": "npm run test:unit && npm run test:e2e",
    "test:e2e": "npm run playwright:install && playwright test --config=./tests/playwright.config.ts",
    "test:unit": "ng test --no-watch",
    "watch": "ng build --watch --configuration development"
  },
  "lint-staged": {
    ".vscode/settings.json": [
      "sort-json --indent 2 --depth 4",
      "eslint -c ./eslint.config.js --fix"
    ],
    "package.json": [
      "sort-package-json",
      "eslint -c ./eslint.config.js --fix"
    ],
    "src/**/*.{html,ts}": [
      "ng-lint-staged lint:angular --fix --"
    ],
    "src/**/*.scss": [
      "stylelint --fix"
    ],
    "tests/**/*.ts": [
      "eslint -c ./tests/eslint.config.js --fix"
    ],
    "!(package|package-lock|**/settings).{json,jsonc,json5}": [
      "eslint -c ./eslint.config.js --fix"
    ],
    "**/*.md": [
      "eslint -c ./eslint.config.js --fix"
    ],
    "!**/*.{json,jsonc,json5,md,html,ts}": [
      "prettier --write --ignore-unknown"
    ]
  },
  "dependencies": {
    "@angular/cdk": "^22",
    "@angular/common": "^22",
    "@angular/compiler": "^22",
    "@angular/core": "^22",
    "@angular/forms": "^22",
    "@angular/material": "^22",
    "@angular/platform-browser": "^22",
    "@angular/router": "^22",
    "iframe-resizer": "^4",
    "rxjs": "^7",
    "tslib": "^2"
  },
  "devDependencies": {
    "@angular/build": "^22",
    "@angular/cli": "^22",
    "@angular/compiler-cli": "^22",
    "@eslint/js": "^9",
    "@eslint/json": "^2",
    "@eslint/markdown": "^8",
    "@playwright/test": "^1",
    "@types/iframe-resizer": "^4",
    "@types/node": "^26",
    "@vitest/coverage-v8": "^4",
    "angular-eslint": "^22",
    "eslint": "^9",
    "eslint-config-prettier": "^10",
    "eslint-import-resolver-typescript": "^4",
    "eslint-plugin-depend": "^1",
    "eslint-plugin-import": "^2",
    "eslint-plugin-prettier": "^5",
    "husky": "^9",
    "jsdom": "^29",
    "lint-staged": "^17",
    "ng-lint-staged": "^12",
    "prettier": "^3",
    "sort-json": "^2",
    "sort-package-json": "^4",
    "stylelint": "^17",
    "stylelint-config-standard-scss": "^17",
    "stylelint-prettier": "^5",
    "typescript": "~6.0",
    "typescript-eslint": "^8",
    "vitest": "^4"
  },
  "packageManager": "npm@11.17.0",
  "allowScripts": {
    "@parcel/watcher@2.5.6": true,
    "esbuild@0.28.1": true,
    "esbuild@0.27.7": true,
    "fsevents@2.3.2": true,
    "fsevents@2.3.3": true,
    "iframe-resizer@4.4.5": true,
    "lmdb@3.5.4": true,
    "msgpackr-extract@3.0.4": true,
    "unrs-resolver@1.12.2": true
  }
}
